htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.pytest_cache/
.tox/
.nox/
.hypothesis/

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# ----------------------------- Node.js / JS ----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ----------------------------- Docker ----------------------------------------
docker-compose.override.yml
*.tar
*.tar.gz

# ----------------------------- IDE / Editor ----------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swap
*~
*.bak
*.orig
\#*\#
.#*

