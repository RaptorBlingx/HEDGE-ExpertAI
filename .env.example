# =============================================================================
# HEDGE-ExpertAI Environment Configuration
# Copy to .env and adjust as needed. Every default here matches
# docker-compose.yml and shared/hedge_shared/config.py.
# =============================================================================

# --- LLM (Ollama) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3.5:2b
OLLAMA_TIMEOUT=180
OLLAMA_THINK=false

# --- Vector DB (Qdrant) ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Embedding ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Feature flags ---
RASA_ENABLED=false
RERANKER_ENABLED=false
RASA_URL=http://rasa:5005
RASA_TIMEOUT=5
RASA_CONFIDENCE_THRESHOLD=0.60
RASA_SHADOW_MODE=false
RASA_CIRCUIT_OPEN_SECONDS=60

# --- App Store API ---
MOCK_API_URL=http://mock-api:9000
# Set HEDGE_API_URL to the real HEDGE-IoT App Store API URL when available.
# If empty, MOCK_API_URL is used as fallback.
HEDGE_API_URL=

# --- Ingestion ---
INGEST_INTERVAL_SECONDS=7200

# --- Service ports ---
GATEWAY_PORT=8080
CHAT_INTENT_PORT=8001
EXPERT_RECOMMEND_PORT=8002
DISCOVERY_RANKING_PORT=8003
METADATA_INGEST_PORT=8004
MOCK_API_PORT=9000

# --- General ---
LOG_LEVEL=INFO
APP_VERSION=0.2.0

# --- Security ---
# Set a secret API key to protect gateway endpoints (leave empty for open access).
GATEWAY_API_KEY=
# Comma-separated list of allowed CORS origins (default: * for development).
CORS_ALLOWED_ORIGINS=*
TRUST_PROXY_HEADERS=false
ENABLE_HSTS=false
ENABLE_RBAC=false

# --- OAuth / OIDC ---
OAUTH_ENABLED=false
OAUTH_ISSUER=
OAUTH_AUDIENCE=hedge-expert-api
OAUTH_CLIENT_ID=hedge-expert-api
OAUTH_JWKS_URL=
# For local/testing only. Leave empty in production and use JWKS instead.
OAUTH_SHARED_SECRET=
OAUTH_JWT_ALGORITHMS=RS256
RBAC_ADMIN_ROLES=admin,administrator
RBAC_ANALYST_ROLES=analyst,admin

# --- TLS Edge ---
TLS_SERVER_NAME=localhost
TLS_SELF_SIGNED_DAYS=30
TLS_CERT_PATH=
TLS_KEY_PATH=

# --- Keycloak bootstrap ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me
KEYCLOAK_PORT=8081

# --- Service URLs (inter-service) ---
CHAT_INTENT_URL=http://chat-intent:8001
EXPERT_RECOMMEND_URL=http://expert-recommend:8002
DISCOVERY_RANKING_URL=http://discovery-ranking:8003
METADATA_INGEST_URL=http://metadata-ingest:8004
